# Copy to .env and fill in real values. Never commit .env itself.

FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-different-long-random-string

# PostgreSQL — change port to 5433 if 5432 is taken on your machine
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secure_exam_p6_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secure_exam_p6_test

# Comma-separated list of allowed frontend origins, or * for dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
